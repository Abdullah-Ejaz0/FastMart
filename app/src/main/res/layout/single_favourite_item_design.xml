<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="70dp"
        android:layout_height="70dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="2dp">

        <ImageView
            android:id="@+id/fav_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/headphone_black"/>
    </androidx.cardview.widget.CardView>

    <Space
        android:layout_width="8dp"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/fav_new_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_108_92"
                android:textColor="@color/red"
                android:textStyle="bold"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/fav_org_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_199_92"
                android:textColor="@color/subtext"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/fav_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/r_de_podmic"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/fav_model"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Model: WH-10000XM6"
            android:textColor="@color/subtext"
            android:textSize="10sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/fav_cart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"/>
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/fav_more"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more"
            android:contentDescription="More options"/>
    </LinearLayout>

</LinearLayout>