<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/deal_card"
    android:layout_width="330dp"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="20dp"
    android:background="@color/grey"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp">

        <ImageView
            android:id="@+id/deal_img"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:src="@drawable/rode_mic"
            android:scaleType="centerCrop"/>

        <androidx.cardview.widget.CardView
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:cardCornerRadius="15dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:clickable="false"
            android:focusable="false"
            android:background="@color/white">

            <ImageView
                android:id="@+id/deal_fav"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_favorite_empty"
                android:scaleType="centerInside"
                android:clickable="false"
                android:focusable="false"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/text_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/deal_img"
            android:layout_marginStart="10dp"
            android:layout_alignTop="@id/deal_img"
            android:layout_alignBottom="@id/deal_img">

            <TextView
                android:id="@+id/deal_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/data_type"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="30dp"
                android:textColor="@color/subtext"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
            <TextView
                android:id="@+id/deal_nprice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Data_Price"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="#FF0000"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="4dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Data_Price"
                android:textStyle="bold"
                android:textSize="12sp"
                android:id="@+id/deal_oprice"
                android:textColor="@color/subtext"
                android:layout_marginTop="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/deal_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/r_de_podmic"
                android:textStyle="bold"
                android:textSize="14sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/deal_desc"
                android:layout_width="125dp"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:text="@string/dynamic_microphone_speaker_microphone"
                android:textColor="@color/subtext"
                android:fontFamily="sans-serif-condensed-medium"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>